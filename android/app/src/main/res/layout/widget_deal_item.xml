<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="#CC000000"
  android:padding="8dp">

  <LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_alignParentLeft="true"
    android:layout_centerVertical="true"
    android:gravity="center_vertical">

    <ImageView
      android:id="@+id/widget_store_icon"
      android:layout_width="24dp"
      android:layout_height="24dp"
      android:layout_marginEnd="8dp"
      android:scaleType="fitCenter"
      android:contentDescription="Store Icon" />

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <TextView
        android:id="@+id/widget_store"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Epic Games Store"
        android:textColor="#EEEEEE"
        android:textSize="11sp" />

      <TextView
        android:id="@+id/widget_normal_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$89.99"
        android:textColor="#AAAAAA"
        android:textSize="10sp" />
    </LinearLayout>

  </LinearLayout>

  <LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_alignParentRight="true"
    android:layout_centerVertical="true"
    android:orientation="vertical"
    android:gravity="end">

    <TextView
      android:id="@+id/widget_sale_price"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="$4.49"
      android:textColor="#E1FF00"
      android:textSize="16sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_savings"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="-95%"
      android:textColor="#00FF41"
      android:textSize="10sp"
      android:textStyle="bold" />
  </LinearLayout>
</RelativeLayout>
